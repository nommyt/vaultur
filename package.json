{
	"name": "vaultur",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Bitwarden-compatible server for Cloudflare Workers (Hono + D1 + R2 + KV + Durable Objects + Email).",
	"license": "AGPL-3.0-only",
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.9.0",
	"scripts": {
		"dev": "bash scripts/ensure-web-vault.sh && wrangler dev",
		"deploy": "bash scripts/ensure-web-vault.sh && wrangler deploy",
		"build": "bash scripts/ensure-web-vault.sh && wrangler deploy --dry-run --outdir dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply vaultur --local",
		"db:migrate:remote": "wrangler d1 migrations apply vaultur --remote",
		"web-vault:fetch": "bash scripts/fetch-web-vault.sh",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check ."
	},
	"dependencies": {
		"@msgpack/msgpack": "^3.1.3",
		"drizzle-orm": "^0.44.7",
		"hono": "^4.12.27",
		"mimetext": "^3.0.28",
		"otpauth": "^9.5.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.71",
		"@cloudflare/workers-types": "^4.20260701.1",
		"drizzle-kit": "^0.31.10",
		"lefthook": "^2.1.9",
		"oxfmt": "^0.57.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.6",
		"wrangler": "^4.106.0"
	}
}
