{
  "name": "@vaultur/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply vaultur --local",
    "db:migrate:remote": "wrangler d1 migrations apply vaultur --remote",
    "web-vault:fetch": "bash ../../scripts/fetch-web-vault.sh"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@vaultur/db": "workspace:*",
    "@vaultur/shared": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.27",
    "mimetext": "^3.0.28",
    "otpauth": "^9.5.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20260701.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.106.0"
  }
}
